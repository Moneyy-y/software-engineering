.banner { height: 400rpx; }
.banner-img { width: 100%; height: 400rpx; }
.title { font-size: 36rpx; font-weight: bold; }
.row { display: flex; gap: 24rpx; margin: 16rpx 0; align-items: center; }
.price { color: #f56c6c; font-size: 32rpx; font-weight: bold; }
.desc { display: block; margin-top: 16rpx; color: #666; }
.actions { display: flex; gap: 20rpx; padding: 0 20rpx 20rpx; }
.section-title { font-weight: bold; font-size: 30rpx; display: block; margin-bottom: 16rpx; }
.review-item { border-top: 1rpx solid #eee; padding: 20rpx 0; }
.review-head { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
