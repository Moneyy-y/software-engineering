<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="error card" wx:if="{{!loading && loadError}}">
    <text>{{loadError}}</text>
    <button size="mini" type="primary" bindtap="load">重新加载</button>
  </view>
  <view wx:if="{{!loading && !loadError && list.length}}" class="toolbar">
    <text class="text-muted">共 {{list.length}} 条</text>
    <text class="clear-btn" bindtap="clearAll">清空</text>
  </view>
  <view
    wx:if="{{!loading && !loadError}}"
    class="card msg {{item.linkable ? 'msg-link' : ''}}"
    wx:for="{{list}}"
    wx:key="messageId"
    data-index="{{index}}"
    bindtap="openMessage"
  >
    <view class="head">
      <text class="title">{{item.title}}</text>
      <text class="type-tag">{{item.typeLabelText}}</text>
    </view>
    <text class="content">{{item.content}}</text>
    <view class="foot">
      <text class="text-muted">{{item.createTime}}</text>
      <view class="foot-actions">
        <text class="link-hint" wx:if="{{item.linkable}}">点击查看</text>
        <text class="del" catchtap="removeOne" data-id="{{item.messageId}}">删除</text>
      </view>
    </view>
  </view>
  <view wx:if="{{!loading && !loadError && !list.length}}" class="empty card">
    暂无消息。评价、帖子审核或反馈回复后会在此通知
  </view>
</view>
