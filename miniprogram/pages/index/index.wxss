.search-bar { display: flex; padding: 20rpx; gap: 12rpx; background: #fff; align-items: center; }
.search-bar input { flex: 1; background: #f5f7fa; padding: 16rpx 24rpx; border-radius: 32rpx; font-size: 28rpx; }
.filter-chip { padding: 14rpx 20rpx; background: #ecf5ff; color: #409EFF; border-radius: 32rpx; font-size: 24rpx; white-space: nowrap; }
.filter-chip.primary { background: #409EFF; color: #fff; }

.filter-panel { background: #fff; margin: 0 20rpx 16rpx; padding: 20rpx; border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.filter-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.filter-row .label { width: 100rpx; color: #666; font-size: 28rpx; }
.picker-val { flex: 1; text-align: right; color: #333; font-size: 28rpx; }
.filter-actions { display: flex; justify-content: flex-end; gap: 16rpx; margin-top: 20rpx; }

.active-tags { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 0 20rpx 12rpx; }
.tag { font-size: 22rpx; padding: 6rpx 16rpx; background: #f0f9eb; color: #67c23a; border-radius: 20rpx; }

.waterfall { display: flex; padding: 10rpx; gap: 16rpx; align-items: flex-start; }
.column { flex: 1; min-width: 0; }
.dish-card { background: #fff; border-radius: 16rpx; overflow: hidden; margin-bottom: 16rpx; }
.cover { width: 100%; display: block; background: #eee; }
.info { padding: 16rpx; }
.name { font-size: 28rpx; font-weight: bold; display: block; }
.meta { display: flex; justify-content: space-between; margin: 8rpx 0; }
.price { color: #f56c6c; font-weight: bold; }
.category, .shop { font-size: 22rpx; display: block; margin-top: 4rpx; }
.empty { text-align: center; padding: 100rpx; color: #999; }
