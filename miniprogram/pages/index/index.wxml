<view class="search-bar">
  <input placeholder="搜索菜品" value="{{keyword}}" bindinput="onSearch" confirm-type="search" bindconfirm="loadDishes" />
  <picker mode="selector" range="{{shops}}" range-key="name" bindchange="onShopChange">
    <view class="filter-chip">{{shopName || '全部食堂'}}</view>
  </picker>
  <view class="filter-chip primary" bindtap="toggleFilter">筛选</view>
</view>

<view class="filter-panel" wx:if="{{showFilter}}">
  <view class="filter-row">
    <text class="label">菜系</text>
    <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="picker-val">{{categoryLabel}}</view>
    </picker>
  </view>
  <view class="filter-row">
    <text class="label">价格</text>
    <picker mode="selector" range="{{priceRanges}}" range-key="label" value="{{priceIndex}}" bindchange="onPriceChange">
      <view class="picker-val">{{priceLabel}}</view>
    </picker>
  </view>
  <view class="filter-row">
    <text class="label">距离</text>
    <picker mode="selector" range="{{distanceOptions}}" range-key="label" value="{{distanceIndex}}" bindchange="onDistanceChange">
      <view class="picker-val">{{distanceLabel}}</view>
    </picker>
  </view>
  <view class="filter-row">
    <text class="label">排序</text>
    <picker mode="selector" range="{{sortOptions}}" range-key="label" value="{{sortIndex}}" bindchange="onSortChange">
      <view class="picker-val">{{sortLabel}}</view>
    </picker>
  </view>
  <view class="filter-actions">
    <button size="mini" bindtap="resetFilter">重置</button>
    <button size="mini" type="primary" bindtap="applyFilter">应用</button>
  </view>
</view>

<view class="active-tags" wx:if="{{categoryLabel !== '全部菜系' || priceLabel !== '不限价格' || distanceLabel !== '不限距离' || sortLabel !== '综合推荐'}}">
  <text class="tag" wx:if="{{categoryLabel !== '全部菜系'}}">{{categoryLabel}}</text>
  <text class="tag" wx:if="{{priceLabel !== '不限价格'}}">{{priceLabel}}</text>
  <text class="tag" wx:if="{{distanceLabel !== '不限距离'}}">{{distanceLabel}}</text>
  <text class="tag" wx:if="{{sortLabel !== '综合推荐'}}">{{sortLabel}}</text>
</view>

<view class="waterfall">
  <view class="column">
    <view class="dish-card" wx:for="{{leftColumn}}" wx:key="dishId" bindtap="goDetail" data-id="{{item.dishId}}">
      <image class="cover" src="{{item.coverImage}}" mode="widthFix" />
      <view class="info">
        <text class="name">{{item.name}}</text>
        <view class="meta">
          <text class="score">★ {{item.avgScore}}</text>
          <text class="price">¥{{item.price}}</text>
        </view>
        <text class="category text-muted" wx:if="{{item.category}}">{{item.category}}</text>
        <text class="shop text-muted">{{item.shopName}}{{item.distanceText ? ' · ' + item.distanceText : ''}}</text>
      </view>
    </view>
  </view>
  <view class="column">
    <view class="dish-card" wx:for="{{rightColumn}}" wx:key="dishId" bindtap="goDetail" data-id="{{item.dishId}}">
      <image class="cover" src="{{item.coverImage}}" mode="widthFix" />
      <view class="info">
        <text class="name">{{item.name}}</text>
        <view class="meta">
          <text class="score">★ {{item.avgScore}}</text>
          <text class="price">¥{{item.price}}</text>
        </view>
        <text class="category text-muted" wx:if="{{item.category}}">{{item.category}}</text>
        <text class="shop text-muted">{{item.shopName}}{{item.distanceText ? ' · ' + item.distanceText : ''}}</text>
      </view>
    </view>
  </view>
</view>
<view wx:if="{{!leftColumn.length && !rightColumn.length}}" class="empty">暂无菜品，试试调整筛选条件</view>
