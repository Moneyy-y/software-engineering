.title { font-size: 34rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.content { display: block; color: #666; margin-bottom: 24rpx; }
.img-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.thumb { width: 200rpx; height: 200rpx; border-radius: 8rpx; }
.actions { margin-bottom: 24rpx; color: #409EFF; display: flex; gap: 32rpx; }
.report-link { color: #f56c6c; font-size: 26rpx; }
.section { font-weight: bold; display: block; margin-bottom: 16rpx; }
.comment { padding: 16rpx 0; border-top: 1rpx solid #eee; }
.comment-meta { display: flex; justify-content: space-between; margin-bottom: 8rpx; font-size: 24rpx; color: #999; }
.floor { color: #409EFF; }
.comment-content { display: block; color: #333; }
.reply { display: flex; gap: 16rpx; margin-top: 24rpx; }
.reply input { flex: 1; background: #f5f7fa; padding: 16rpx; border-radius: 8rpx; }
